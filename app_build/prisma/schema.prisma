// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  role      String   @default("ATTENDEE") // ATTENDEE, STAFF, ADMIN
  createdAt DateTime @default(now())
  
  tickets   Ticket[]
  orders    Order[]
}

model Ticket {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  eventName String
  venueName String
  eventStart DateTime
  section   String
  row       String
  seat      String
  gate      String
  qrCode    String   @unique
  status    String   @default("ACTIVE") // ACTIVE, SCANNED
  createdAt DateTime @default(now())
}

model MenuItem {
  id        String   @id @default(uuid())
  name      String
  price     Float
  category  String
  prepTime  String
  icon      String
  inStock   Boolean  @default(true)
  
  orderItems OrderItem[]
}

model Order {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  status    String   @default("PENDING") // PENDING, PREPARING, READY, PICKED_UP
  total     Float
  fulfillmentMode String
  etaMinutes Int
  pickupZone String?
  seatLabel String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  items     OrderItem[]
}

model OrderItem {
  id         String   @id @default(uuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id])
  menuItemId String
  menuItem   MenuItem @relation(fields: [menuItemId], references: [id])
  quantity   Int
}

model HubEvent {
  id        String   @id @default(uuid())
  type      String   // PLAY, POLL, UPDATE
  text      String
  icon      String
  pollOptions Json?
  createdAt DateTime @default(now())
}

model VenueWaitPoint {
  id            String   @id
  name          String
  category      String
  waitMinutes   Int
  travelMinutes Int
  zone          String
  status        String
  icon          String
  routeHint     String
  sortOrder     Int      @default(0)
  isRecommended Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model VenueAlert {
  id          String   @id @default(uuid())
  title       String
  detail      String
  level       String
  icon        String
  ctaLabel    String?
  ctaTargetId String?
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
}

model LiveGameState {
  id            String   @id @default(uuid())
  label         String   @unique @default("primary")
  homeTeam      String
  awayTeam      String
  homeScore     Int
  awayScore     Int
  periodLabel   String
  clock         String
  possessionPct Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
